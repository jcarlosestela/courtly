PORT=3000
NODE_ENV=development

# Global kill switch for group automation
GROUP_AUTOMATION_ENABLED=true

# Group provider: baileys | official | manual
GROUP_PROVIDER=baileys

# Comma-separated allowlist of group JIDs (e.g. 120363043210@g.us,120300000001@g.us)
GROUP_ALLOWLIST=

# Group automation throttling
GROUP_RATE_LIMIT_PER_GROUP_PER_MINUTE=20
GROUP_RATE_LIMIT_GLOBAL_PER_MINUTE=100

# Baileys auth/session folder path
BAILEYS_SESSION_PATH=.baileys-session

# WhatsApp Cloud API (direct channel)
WA_CLOUD_API_BASE_URL=https://graph.facebook.com
WA_CLOUD_API_VERSION=v22.0
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_WEBHOOK_VERIFY_TOKEN=

# Direct webhook idempotency cache TTL in seconds
DIRECT_IDEMPOTENCY_TTL_SECONDS=86400
