{
  "name": "whatsapp-padel-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Hybrid WhatsApp integration skeleton (official DM + pluggable groups)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "bash ./scripts/security-check.sh",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run test:coverage && npm run security:audit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.0.18"
  }
}
